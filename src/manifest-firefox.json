{
    "browser_specific_settings": {
        "gecko": {
            "id": "addon@walreader.org",
            "strict_min_version": "78.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "background": {
        "page": "background/index.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "inject/fallback.js"
            ],
            "run_at": "document_start",
            "all_frames": true,
            "match_about_blank": true,
            "world": "MAIN"
        },
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "inject/index.js"
            ],
            "run_at": "document_start",
            "all_frames": true,
            "match_about_blank": true,
            "world": "ISOLATED"
        }
    ],
    "permissions": [
        "alarms",
        "contextMenus",
        "storage",
        "tabs",
        "theme",
        "<all_urls>"
    ],
    "optional_permissions": []
}